{
  "name": "onboardbot",
  "version": "0.1.0",
  "type": "module",
  "description": "RAG-based onboarding assistant for LangChain codebases. Final project for Path Code - Academia Lab 10.",
  "private": true,
  "scripts": {
    "dev": "tsx src/index.ts",
    "ingest": "tsx src/ingest/buildIndex.ts",
